# Copy to .env and adjust. Defaults assume Ollama on the same box.

# Point at the external 1.5TB SSD so the index isn't on the 256GB internal
DATA_DIR=/data/brain
CHUNKS_PATH=/data/brain/chunks.jsonl
CHROMA_DIR=/data/brain/chroma
COLLECTION=second_brain

# Embeddings: always local Ollama (free, private, fast)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Generation provider: ollama (local) | gemini (free cloud fallback)
GEN_PROVIDER=ollama
GEN_MODEL=qwen2.5:7b
# If GEN_PROVIDER=gemini, set these instead:
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Retrieval tuning
TOP_K=6
MIN_SIMILARITY=0.35
GRAPH_HOP=true
